# Release signing config template for SleepGuard.
#
# 1. Create your upload keystore ONCE (keep the .jks file and these passwords safe — if you lose
#    them you can no longer update the app on Google Play):
#
#      keytool -genkeypair -v -keystore sleepguard-upload.jks -keyalg RSA -keysize 2048 \
#        -validity 10000 -alias sleepguard
#
# 2. Copy this file to "keystore.properties" (same folder, project root) and fill in the real values.
# 3. keystore.properties and *.jks are gitignored — never commit them.
#
# app/build.gradle reads these to sign the release AAB. If keystore.properties is absent, the release
# build is left unsigned (debug builds and tests are unaffected).

storeFile=../sleepguard-upload.jks
storePassword=CHANGE_ME
keyAlias=sleepguard
keyPassword=CHANGE_ME
