<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      PACKAGE_USAGE_STATS is a special "app ops" permission. Declaring it here is
      required, but it is NOT granted at install time and cannot be requested as a
      runtime permission. The user must enable Usage Access manually in Settings.
      tools:ignore silences the lint warning about declaring a protected permission.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- No INTERNET permission: the app is fully on-device. Nothing is uploaded; the only data
         that ever leaves is a user-initiated backup file shared via the FileProvider below. -->

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SleepGuardPOC">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Lets the "Export backup" action share a temp JSON file from cacheDir via a content URI
             (no Binder size limit, unlike clipboard / EXTRA_TEXT). Not exported. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
