<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      PACKAGE_USAGE_STATS is a special "app ops" permission. Declaring it here is
      required, but it is NOT granted at install time and cannot be requested as a
      runtime permission. The user must enable Usage Access manually in Settings.
      tools:ignore silences the lint warning about declaring a protected permission.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!--
      No INTERNET permission: this POC is fully offline and never sends data anywhere.
      Network access will be added only in the next milestone (sync summary to Base44).
    -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SleepGuardPOC">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
