<resources>
    <string name="app_name">SleepGuard</string>

    <!-- ============================================================
         HERO (user-facing landing) — Hebrew, RTL.
         These strings are the ones rendered in the top landing block.
         ============================================================ -->
    <string name="hero_title">SleepGuard</string>
    <string name="hero_tagline">מנתחת את פעילות הטלפון שלך בלילה. הנתונים נשארים במכשיר שלך בלבד.</string>

    <string name="privacy_message">SleepGuard לא קוראת הודעות, התראות, תוכן אפליקציות, מיקום, מיקרופון או מצלמה. האפליקציה קוראת רק את תזמוני הדלקת/כיבוי המסך מתוך "גישה לנתוני שימוש" של אנדרואיד, כדי לאמוד את פעילות הטלפון בלילה. הנתונים נשמרים במכשיר בלבד ואינם נשלחים לשום מקום.</string>

    <string name="status_granted">גישה לנתוני המערכת: פעילה</string>
    <string name="status_missing">כדי להתחיל, אפשר גישה לנתוני המערכת</string>
    <string name="button_open_settings">אפשר גישה לנתוני המערכת</string>

    <string name="status_success">הנתונים נאספו ונותחו.</string>
    <string name="error_no_permission">לא ניתן לאסוף נתונים ללא גישה לנתוני המערכת. יש לאפשר אותה תחילה.</string>
    <string name="error_no_events">לא נמצאו אירועי מסך לתקופה המבוקשת. ייתכן שהמכשיר לא שמר נתוני שימוש לתקופה זו.</string>
    <string name="error_query_failed">איסוף נתוני השימוש נכשל. בדוק את ההרשאה ונסה שוב.</string>
    <string name="error_no_settings_screen">לא ניתן לפתוח את מסך "גישה לנתוני שימוש" במכשיר זה. אפשר אותה ידנית תחת: הגדרות &gt; אפליקציות &gt; גישה מיוחדת &gt; גישה לנתוני שימוש.</string>

